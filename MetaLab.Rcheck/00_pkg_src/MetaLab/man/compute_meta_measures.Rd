% Generated by hand (replaces previous compute_meta_sdt docs)
\name{compute_meta_measures}
\alias{compute_meta_measures}
\title{Compute meta-d' and related metacognitive measures (Meta Measures)}
\usage{
compute_meta_measures(
  data,
  id_col,
  stim_col,
  resp_col,
  conf_col,
  s1_stim,
  s2_stim,
  s1_resp,
  s2_resp,
  s_param = 1,
  n_restarts = 3,
  min_trials = 10
)
}
\arguments{
\item{data}{A data.frame with one row per trial.}
\item{id_col}{Name of the participant ID column.}
\item{stim_col}{Name of the stimulus column (S1 vs S2).}
\item{resp_col}{Name of the response column (S1 vs S2).}
\item{conf_col}{Name of the confidence column (discrete, ordered; low->high).}
\item{s1_stim}{Value in \code{stim_col} that indicates an S1 trial.}
\item{s2_stim}{Value in \code{stim_col} that indicates an S2 trial.}
\item{s1_resp}{Value in \code{resp_col} that indicates an S1 response.}
\item{s2_resp}{Value in \code{resp_col} that indicates an S2 response.}
\item{s_param}{SD ratio parameter \code{s} (default 1; equal-variance SDT).}
\item{n_restarts}{Number of random restarts for the MLE optimiser.}
\item{min_trials}{Minimum trials per participant required to fit (default 10).}
}
\value{
A data.frame with one row per participant matching the results table produced by
the Meta Measures Shiny app in this repository. Columns include \code{d_prime},
\code{meta_d_prime}, \code{M_ratio}, \code{M_diff}, \code{delta_conf},
\code{phi}, \code{gamma}, \code{auc2}, \code{bias}, \code{abs_accuracy},
\code{discrimination}, \code{scatter}, \code{logL}, and \code{note}.
}
\description{
Computes the same per-participant results table produced by the Meta Measures
Shiny app included in this repository (\code{Meta Measures/app.R}). Includes a
native R implementation of the Maniscalco & Lau meta-d' MLE fit plus several
trial-level metacognitive metrics.
}
\examples{
\dontrun{
res <- compute_meta_measures(
  data = df,
  id_col = "participant_id",
  stim_col = "stimulus",
  resp_col = "response",
  conf_col = "confidence",
  s1_stim = "S1",
  s2_stim = "S2",
  s1_resp = "S1",
  s2_resp = "S2"
)
}
}

